# LLM configuration
GEMINI_API_KEY=example_api_key
GEMINI_MODEL=gemini-3.1-pro-preview
GEMINI_TEMPERATURE=0.9
# 8192 leaves headroom for chain-of-thought on reasoning-first Pro models.
GEMINI_MAX_TOKENS=8192
# Set to true ONLY for models that support ThinkingConfig(thinking_budget=0).
# Gemini 3.x Pro preview rejects budget 0 ("This model only works in thinking
# mode") — keep false there and just allocate enough output tokens.
GEMINI_DISABLE_THINKING=false

# Per-million-token prices used by EstimatedCostCalculator to convert token
# counts into an approximate USD bill. Defaults match Gemini 3.1 Pro Preview
# at ≤200K context ($2 input, $12 output). Update when switching models:
#   - gemini-2.0-flash:          0.10 input / 0.40 output
#   - gemini-2.5-pro (≤200K):    1.25 input / 10.00 output
#   - gemini-3.1-pro-preview:    2.00 input / 12.00 output
# Reasoning ("thoughts") tokens are billed as output.
GEMINI_INPUT_PRICE_PER_M=2.0
GEMINI_OUTPUT_PRICE_PER_M=12.0

# LLM reliability stack (timeout + retry).
# Reasoning-first Pro models (gemini-2.5-pro / gemini-3.x) routinely spend
# 60-120 s on chain-of-thought per call. 120 s accommodates the upper end;
# anything beyond that usually means the model has wandered. Lower to 20 s
# for gemini-2.0-flash. Retries are 2 — re-submitting after a timeout
# rarely helps but still covers transient 5xx / rate-limit responses.
LLM_TIMEOUT_SEC=120
LLM_RETRY_MAX_ATTEMPTS=3
# Empty value = auto (gemini if API key set, else mock).
# Do NOT add inline comments to LLM_PROVIDER — docker-compose's env_file
# parser keeps them as part of the value.
LLM_PROVIDER=

# Data paths
CORPUS_PATH=corpus/uk_theme_reference_corpus.json
METRIC_EXAMPLES_PATH=corpus/uk_metric-rhyme_reference_corpus.json

# Embedding model
LABSE_MODEL=sentence-transformers/LaBSE
# Set to true to use the OfflineDeterministicEmbedder (no network).
OFFLINE_EMBEDDER=false

# Server
HOST=127.0.0.1
PORT=8000
DEBUG=false
