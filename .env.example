# LLM configuration
GEMINI_API_KEY=example_api_key
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TEMPERATURE=0.9
GEMINI_MAX_TOKENS=4096
LLM_PROVIDER=            # "" = auto (gemini if API key set, else mock)

# Data paths
CORPUS_PATH=corpus/uk_theme_reference_corpus.json
METRIC_EXAMPLES_PATH=corpus/uk_metric-rhyme_reference_corpus.json

# Embedding model
LABSE_MODEL=sentence-transformers/LaBSE
OFFLINE_EMBEDDER=false    # when true, use OfflineDeterministicEmbedder

# Server
HOST=127.0.0.1
PORT=8000
DEBUG=false
